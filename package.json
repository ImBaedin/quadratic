{
  "name": "quadratic",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.2.2",
      "zod": "^4.1.13",
      "lucide-react": "^0.546.0",
      "next-themes": "^0.4.6",
      "inngest": "^3.39.1",
      "react": "^19.2.3",
      "react-dom": "^19.2.3",
      "sonner": "^2.0.5",
      "tailwindcss": "^4.1.18",
      "convex": "^1.33.1",
      "@types/react": "^19.2.10",
      "@types/react-dom": "^19.2.3",
      "alchemy": "^0.90.0"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "check-types": "turbo check-types",
    "test": "bun test",
    "dev:web": "turbo -F web dev",
    "dev:server": "turbo -F @quadratic/backend dev",
    "dev:setup": "turbo -F @quadratic/backend dev:setup",
    "deploy": "turbo -F @quadratic/infra deploy",
    "destroy": "turbo -F @quadratic/infra destroy",
    "check": "oxlint && oxfmt --write"
  },
  "dependencies": {
    "@quadratic/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20251213.0",
    "@quadratic/config": "workspace:*",
    "@types/node": "^24.3.0",
    "oxfmt": "^0.26.0",
    "oxlint": "^1.41.0",
    "turbo": "^2.8.12",
    "typescript": "^5"
  },
  "packageManager": "bun@1.3.9"
}
