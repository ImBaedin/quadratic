# Shared app env for local dev and Alchemy deploys.
# Copy this file to `.env` at the repo root and fill in the values you need.

# Public web client
VITE_CONVEX_URL=https://<your-convex-deployment>.convex.cloud

# App base URL
APP_URL=http://localhost:3001

# Server-side backend URL used by HTTP clients in the app.
# Usually this matches VITE_CONVEX_URL for local dev.
CONVEX_URL=https://<your-convex-deployment>.convex.cloud

# Used as a fallback for cookie encryption if WORKOS_COOKIE_PASSWORD is unset.
# Must be at least 32 characters.
APP_COOKIE_SECRET=development-cookie-secret-please-change

# Set to 1 to bypass live WorkOS auth while wiring the app up locally.
ENABLE_MOCK_AUTH=1

# WorkOS
WORKOS_CLIENT_ID=
WORKOS_API_KEY=
# Must be at least 32 characters when using WorkOS cookies.
WORKOS_COOKIE_PASSWORD=
WORKOS_REDIRECT_URI=http://localhost:3001/auth/callback
WORKOS_LOGOUT_REDIRECT_URI=http://localhost:3001/
WORKOS_BASE_URL=https://api.workos.com

# GitHub App
GITHUB_APP_ID=
GITHUB_APP_CLIENT_ID=
GITHUB_APP_CLIENT_SECRET=
# If you paste a PEM key here, keep the newline escapes intact.
GITHUB_APP_PRIVATE_KEY=
GITHUB_APP_WEBHOOK_SECRET=
GITHUB_APP_NAME=quadratic
GITHUB_APP_INSTALL_URL=
GITHUB_API_BASE_URL=https://api.github.com
GITHUB_WEB_BASE_URL=https://github.com

# Inngest
INNGEST_APP_ID=quadratic-web
INNGEST_BASE_URL=
INNGEST_EVENT_KEY=
